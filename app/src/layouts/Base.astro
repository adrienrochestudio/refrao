---
// Mise en page commune : tête (polices + style global réutilisé tel quel
// pendant la migration), barre supérieure, fond. Le CSS sera refactoré plus tard ;
// pour l'instant on réutilise style.css à l'identique pour valider la chaîne.
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  active?: string;
}
const { title = 'refrão', active } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,700;12..96,800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={withBase('style.css')} />
  </head>
  <body>
    <div class="bg-fx"></div>

    <header class="topbar">
      <a class="brand" href={withBase()}><span class="dot"></span><b>refrão</b></a>
      <nav class="nav">
        <a href={withBase('apprendre')} data-page="learn" class={active === 'learn' ? 'on' : undefined}>Apprendre</a>
        <a href={withBase('progression')} data-page="prog" class={active === 'prog' ? 'on' : undefined}>Progression</a>
      </nav>
      <div id="authSlot" style="display:flex;gap:8px;align-items:center"></div>
    </header>

    <slot />
  </body>
</html>
