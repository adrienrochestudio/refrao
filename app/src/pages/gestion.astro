---
import Base from '../layouts/Base.astro';
---

<Base title="refrão — espace gestion" active="">
  <main class="shell">
    <div id="cohortPanel" class="cohort-panel"></div>

    <div class="section-head">
      <div>
        <h2><span class="live-dot"></span>Banque de musiques</h2>
        <div class="sub" id="bankSub">Bibliothèque commune, rangée par langue</div>
      </div>
      <button class="btn btn-primary" onclick="openEditor()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg>
        Ajouter une musique
      </button>
    </div>
    <div id="bankList"></div>
  </main>

  <!-- MODAL EDITEUR -->
  <div class="modal-bg" id="editorBg">
    <div class="modal">
      <h3 id="edTitle">Ajouter une musique</h3>
      <div class="lead">Collez les paroles et leur traduction, puis reliez les mots ci-dessous.</div>

      <div class="two-col">
        <div class="field"><label>Titre</label><input id="edSongTitle" placeholder="Ex : Águas de Março" /></div>
        <div class="field"><label>Artiste</label><input id="edArtist" placeholder="Ex : Elis Regina" /></div>
      </div>
      <div class="two-col">
        <div class="field"><label>Langue de la chanson</label><select id="edLang"></select></div>
        <div class="field"><label>Niveau CEFR</label><select id="edCefr"></select><div class="hint-small" id="bandHint"></div></div>
      </div>
      <div class="two-col">
        <div class="field"><label>Style / genre</label><select id="edGenre"></select></div>
        <div class="field"><label>Mots-clés (séparés par des virgules)</label><input id="edTags" placeholder="ex : bossa nova, été, années 70" /></div>
      </div>
      <div class="field">
        <label>Lien Deezer</label>
        <div style="display:flex;gap:10px">
          <input id="edDeezer" placeholder="https://www.deezer.com/track/..." style="flex:1" />
          <button class="btn" type="button" onclick="importDeezer()">Récupérer</button>
        </div>
        <div id="dzInfo" class="hidden" style="align-items:center;gap:12px;margin-top:12px">
          <img id="dzCover" alt="" style="width:52px;height:52px;border-radius:10px;object-fit:cover;border:1px solid var(--border)" />
          <div style="flex:1;min-width:0">
            <div id="dzTitle" style="font-weight:600;font-size:.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></div>
            <audio id="dzAudio" controls preload="none" style="width:100%;height:34px;margin-top:4px"></audio>
          </div>
        </div>
      </div>

      <div class="two-col">
        <div class="field"><label>Paroles (langue d'origine) — une ligne par vers, ligne vide entre les sections</label><textarea id="edPt" placeholder="É pau, é pedra..."></textarea></div>
        <div class="field"><label>Traduction (français) — alignée ligne par ligne</label><textarea id="edFr" placeholder="C'est du bois, c'est de la pierre..."></textarea></div>
      </div>

      <div class="field">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:8px">
          <label style="margin:0">Structure (refrain / couplets)</label>
          <button class="btn btn-sm" type="button" onclick="detectStructure()">Détecter la structure</button>
        </div>
        <div id="structPanel" class="struct-panel"><div class="hint-small">Séparez les sections par une ligne vide, puis « Détecter ». Vous pourrez corriger refrain / couplet avant d'enregistrer.</div></div>
      </div>

      <div class="field">
        <label>Relier les mots</label>
        <div class="linker">
          <div class="lead" style="margin:0 0 12px">Sélectionne un ou plusieurs mots à gauche, puis à droite, puis « Lier ». Ça crée une paire de vocabulaire (mot ou expression).</div>
          <div class="linker-cols">
            <div class="tok-box"><div class="cap" id="capPt">Langue d'origine</div><div id="tokPt"></div></div>
            <div class="tok-box"><div class="cap">Français</div><div id="tokFr"></div></div>
          </div>
          <button class="btn btn-sm" onclick="linkSelection()" style="margin-bottom:14px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M9 17H7A5 5 0 0 1 7 7h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8"></path></svg>
          Lier la sélection
          </button>
          <div class="cap" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-mute);margin-bottom:6px">Paires créées (<span id="pairCount">0</span>)</div>
          <div class="pairs" id="pairList"></div>
        </div>
      </div>

      <div class="modal-foot">
        <button class="btn btn-ghost" onclick="closeEditor()">Annuler</button>
        <button class="btn btn-primary" onclick="saveEditor()">Enregistrer</button>
      </div>
    </div>
  </div>

  <script>
    import { boot } from '../lib/gestion';
    boot();
  </script>
</Base>
