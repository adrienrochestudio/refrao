---
import Base from '../layouts/Base.astro';
---

<Base title="refrão — apprendre" active="learn">
  <main class="shell">
    <!-- choix : révision du jour + chansons -->
    <section id="chooser" class="view active">
      <div class="section-head">
        <div><h2><span class="live-dot"></span>Apprendre</h2><div class="sub">Choisis ta langue, puis une chanson</div></div>
      </div>
      <div class="lang-pick" id="langPick"></div>
      <div id="learnList"></div>
    </section>

    <!-- parcours d'une chanson -->
    <section id="song" class="view">
      <a class="back" onclick="showChooser()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M19 12H5M11 18l-6-6 6-6"></path></svg>
        Toutes les chansons
      </a>
      <div id="songView"></div>
    </section>

    <!-- activité (découverte / cloze / révision) -->
    <section id="exercise" class="view"><div class="ex-wrap" id="exWrap"></div></section>
  </main>

  <script>
    import { boot } from '../lib/apprendre';
    boot();
  </script>
</Base>
