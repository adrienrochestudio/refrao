---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/paths';
---

<Base title="refrão · apprendre les langues avec la musique" active="home">
  <main class="shell">
    <div class="landing">
      <div class="kicker" id="greet">boa tarde</div>
      <h1>Apprends les langues<br /><span class="em">en musique</span></h1>
      <p class="lead-sub" id="leadSub">Apprends en chantant.</p>

      <div class="cta-row">
        <a href={withBase('auth')} class="cta" id="ctaLearn">
          Apprendre
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.6"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
          >
        </a>
        <a href={withBase('auth')} class="cta cta-ghost" id="ctaManage">Ouvrir l'espace gestion</a>
      </div>

      <div class="stats stagger" id="statRow" style="margin-top:48px;max-width:560px;width:100%">
        <div class="stat"><div class="n" id="stSongs">0</div><div class="l">chansons</div></div>
        <div class="stat"><div class="n" id="stLearned">0</div><div class="l">chansons complétées</div></div>
        <div class="stat"><div class="n" id="stXp">0</div><div class="l">bonnes réponses</div></div>
      </div>
    </div>
  </main>
</Base>

<script>
  // Îlot client TypeScript : salutation, rotation des sous-titres, et données
  // dynamiques via le SDK Firebase typé (CTA selon le rôle, stats live).
  import { onAuthProfile, getSongs, getProgress, songComplete } from '../lib/refrao';
  import { withBase } from '../lib/paths';

  const greet = document.getElementById('greet');
  if (greet) {
    const h = new Date().getHours();
    greet.textContent = h < 12 ? 'bom dia' : h < 18 ? 'boa tarde' : 'boa noite';
  }

  const LEARNER_SUBS: readonly string[] = [
    'Apprends en chantant.',
    'Au rythme de tes chansons préférées.',
    'Le refrain comme point de départ.',
    'Tes morceaux deviennent tes leçons.',
    'Chante, comprends, retiens.',
    'Du premier mot au refrain par cœur.'
  ];
  const MANAGER_SUBS: readonly string[] = [
    "Donnez à vos élèves le goût d'apprendre.",
    'Vos cohortes, vos chansons, leurs progrès.',
    'Transformez les musiques en leçons vivantes.',
    'Accompagnez chaque apprenant à son rythme.'
  ];

  const sub = document.getElementById('leadSub');
  let subs: readonly string[] = LEARNER_SUBS;
  let si = 0;
  if (sub) {
    setInterval(() => {
      sub.classList.add('fade');
      setTimeout(() => {
        si = (si + 1) % subs.length;
        sub.textContent = subs[si] ?? subs[0]!;
        sub.classList.remove('fade');
      }, 420);
    }, 4200);
  }

  const ctaLearn = document.getElementById('ctaLearn');
  const ctaManage = document.getElementById('ctaManage');
  const statRow = document.getElementById('statRow');
  const elSongs = document.getElementById('stSongs');
  const elLearned = document.getElementById('stLearned');
  const elXp = document.getElementById('stXp');

  onAuthProfile(async ({ user, profile }) => {
    const isManager = !!(user && profile && profile.role === 'manager');
    if (ctaLearn) ctaLearn.setAttribute('href', user ? withBase('apprendre') : withBase('auth'));
    if (ctaManage) ctaManage.setAttribute('href', user ? withBase('gestion') : withBase('auth'));
    subs = isManager ? MANAGER_SUBS : LEARNER_SUBS;
    si = 0;
    if (sub) sub.textContent = subs[0]!;
    if (isManager && statRow) statRow.style.display = 'none';

    if (!user) return;
    try {
      const songs = await getSongs();
      let scope = songs.filter(songComplete);
      if (profile?.lang) scope = scope.filter(s => (s.lang ?? 'pt') === profile.lang);
      const prog = await getProgress(user.uid);
      if (elSongs) elSongs.textContent = String(scope.length);
      if (elLearned) elLearned.textContent = String(Object.values(prog.songs ?? {}).filter(x => x.completed).length);
      if (elXp) elXp.textContent = String((prog.recent ?? []).filter(Boolean).length);
    } catch {
      // En local, App Check / règles peuvent bloquer la lecture : compteurs à 0.
    }
  });
</script>
